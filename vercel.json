{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd client && npx vite build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
